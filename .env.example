# ════════════════════════════════════════════════════════════════════
#  Public (Vite) — safe to commit values, exposed to the browser bundle
# ════════════════════════════════════════════════════════════════════

# Leave VITE_SUPABASE_* empty to run in demo mode (in-memory event bus,
# local tokens). Otherwise grab them from Project Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# UUID of the Supabase `worlds` row that admin changes (mesh, OSM layers,
# colours, …) are persisted to. Defaults to the canonical Manoel Island
# base world if unset. Override to host a private fork.
VITE_WORLD_ID=11111111-1111-4111-8111-111111111111

# How fast a token regenerates locally when Supabase is not configured.
# Default 600000 ms = 10 minutes (matches the production schema).
# VITE_DEMO_REFILL_MS=600000


# ════════════════════════════════════════════════════════════════════
#  Server-only — DO NOT commit. Put these in `.env.local` (gitignored).
#  Used solely by `npm run bootstrap-supabase` for the one-off project
#  setup. Never reach the browser bundle (no `VITE_` prefix).
# ════════════════════════════════════════════════════════════════════

# Same project as VITE_SUPABASE_URL above.
SUPABASE_URL=https://your-project.supabase.co

# Project Settings → API → "service_role" (NOT the anon key).
# This bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The human who will own the public Manoel world.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=at-least-six-chars

# Optional friendly name shown in the dashboard.
# WORLD_NAME=Manoel Island (Public Base)
